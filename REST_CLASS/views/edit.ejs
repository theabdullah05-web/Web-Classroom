<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit</title>
</head>
<body>
    <h1>Edit your post</h1>
    <h3>Post Id: <%=post.id%></h3>
    <h3>Username: <%=post.user%></h3>
    <form method="post" action="/posts/<%=post.id%>?_method=PATCH">
        <textarea placeholder="edit your post" rows="10" cols="35" name="content"><%=post.content%></textarea><br>
        <button>Submit</button>
    </form>
</body>
</html>